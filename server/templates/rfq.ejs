<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= rfq.status === 'rfq' ? 'Request for Quotation' : 'Vendor Quotation' %> - <%= rfq.quotationNumber %></title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Arial', 'Helvetica', sans-serif;
            font-size: 11px;
            line-height: 1.5;
            color: #000;
            padding: 15px;
            max-width: 210mm;
            margin: 0 auto;
        }
        .header {
            text-align: center;
            border: 2px solid #000;
            padding: 15px;
            margin-bottom: 20px;
        }
        .header h1 {
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 5px;
            color: #003366;
            text-transform: uppercase;
        }
        .header .subtitle {
            font-size: 14px;
            font-weight: bold;
            color: #003366;
            margin-bottom: 8px;
        }
        .header .company-address {
            font-size: 10px;
            margin-bottom: 5px;
        }
        .header .company-contact {
            font-size: 10px;
            border-top: 1px solid #eee;
            padding-top: 5px;
        }
        .doc-title {
            text-align: center;
            margin-bottom: 15px;
            background-color: #f3f4f6;
            padding: 5px;
            border: 1px solid #000;
            font-weight: bold;
            font-size: 13px;
        }
        .two-column {
            display: flex;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 20px;
        }
        .column {
            flex: 1;
            border: 1px solid #000;
            padding: 12px;
            background-color: #fafafa;
        }
        .column h3 {
            font-size: 12px;
            margin-bottom: 10px;
            text-decoration: underline;
            font-weight: bold;
        }
        .info-p p {
            margin: 4px 0;
            font-size: 10px;
        }
        .details-grid {
            display: grid;
            grid-template-columns: 120px 1fr;
            gap: 5px;
        }
        .details-grid strong {
            font-weight: bold;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
            border: 1px solid #000;
        }
        table th {
            background-color: #ffff00;
            font-weight: bold;
            padding: 8px 6px;
            text-align: center;
            border: 1px solid #000;
            font-size: 10px;
        }
        table td {
            padding: 8px 6px;
            border: 1px solid #000;
            font-size: 10px;
        }
        .text-center { text-align: center; }
        .text-right { text-align: right; }
        .bold { font-weight: bold; }

        .terms-section {
            border: 1px solid #000;
            padding: 12px;
            margin-bottom: 30px;
        }
        .terms-section h3 {
            font-size: 12px;
            margin-bottom: 8px;
            font-weight: bold;
        }
        .signature-section {
            display: flex;
            justify-content: space-between;
            margin-top: 40px;
        }
        .signature-box {
            text-align: center;
            width: 200px;
        }
        .signature-line {
            border-top: 1px solid #000;
            margin-top: 50px;
            margin-bottom: 5px;
        }
        .footer {
            text-align: center;
            font-size: 9px;
            color: #666;
            margin-top: 30px;
            font-style: italic;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1><%= company.name %></h1>
        <div class="subtitle">HOT RUNNER SYSTEMS</div>
        <div class="company-address">
            <%= company.address %>
        </div>
        <div class="company-contact">
            www.hottipindia.com | <%= company.email %> | Mob: <%= company.phone %>
            <br>
            <strong>GSTIN: <%= company.gstNo %></strong>
        </div>
    </div>

    <div class="doc-title">
        <%= rfq.status === 'rfq' ? 'REQUEST FOR QUOTATION (RFQ)' : 'VENDOR QUOTATION (RECEIVED)' %>
    </div>

    <div class="two-column">
        <div class="column info-p">
            <h3>VENDOR / SUPPLIER</h3>
            <p><strong><%= supplier.name %></strong></p>
            <p><%= supplier.address %></p>
            <p><strong>GSTIN:</strong> <%= supplier.gstNo %></p>
            <p><strong>Phone:</strong> <%= supplier.phone %></p>
            <p><strong>Email:</strong> <%= supplier.email %></p>
        </div>
        <div class="column">
            <h3>DOCUMENT DETAILS</h3>
            <div class="details-grid">
                <strong>Ref No:</strong> <span><%= rfq.quotationNumber %></span>
                <strong>Date:</strong> <span><%= rfq.date %></span>
                <strong>Valid Until:</strong> <span><%= rfq.validUntil || 'N/A' %></span>
                <strong>Subject:</strong> <span><%= rfq.subject %></span>
            </div>
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th style="width: 5%;">Sr.</th>
                <th style="width: 55%;">Description / Material Name</th>
                <th style="width: 15%;">Qty</th>
                <th style="width: 10%;">Unit</th>
                <% if (rfq.status !== 'rfq') { %>
                <th style="width: 15%;">Rate (INR)</th>
                <% } %>
            </tr>
        </thead>
        <tbody>
            <% rfq.items.forEach(function(item, i) { %>
            <tr>
                <td class="text-center bold"><%= i + 1 %></td>
                <td>
                    <div class="bold"><%= item.materialName %></div>
                    <% if (item.type) { %>
                    <div style="font-size: 9px; color: #666;"><%= item.type %></div>
                    <% } %>
                </td>
                <td class="text-center"><%= item.designQty %></td>
                <td class="text-center"><%= item.unit || 'NOS' %></td>
                <% if (rfq.status !== 'rfq') { %>
                <td class="text-right"><%= (item.rate || 0).toLocaleString('en-IN') %></td>
                <% } %>
            </tr>
            <% }) %>
        </tbody>
    </table>

    <div class="terms-section">
        <h3>INSTRUCTIONS / NOTES</h3>
        <p><%= rfq.notes || 'Please provide your best quotation including taxes and lead time.' %></p>
    </div>

    <div class="signature-section">
        <div class="signature-box">
            <div class="signature-line"></div>
            <p>Customer Signature</p>
        </div>
        <div class="signature-box">
            <p><strong>For <%= company.name %></strong></p>
            <div class="signature-line"></div>
            <p>Authorised Signatory</p>
        </div>
    </div>

    <div class="footer">
        This is a Computer Generated Document
    </div>
</body>
</html>

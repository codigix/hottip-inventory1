<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delivery Challan - <%= challan.challanNumber %></title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Arial', 'Helvetica', sans-serif;
            font-size: 11px;
            line-height: 1.5;
            color: #000;
            padding: 15px;
            max-width: 210mm;
            margin: 0 auto;
        }
        .header {
            text-align: center;
            border-bottom: 3px solid #333;
            padding-bottom: 12px;
            margin-bottom: 15px;
        }
        .header h1 {
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 3px;
            text-transform: uppercase;
            color: #1a1a1a;
        }
        .header .title {
            font-size: 16px;
            font-weight: bold;
            margin-bottom: 8px;
            color: #2563eb;
        }
        .company-info {
            text-align: center;
            margin-bottom: 8px;
            font-size: 10px;
        }
        .company-details {
            display: flex;
            justify-content: space-between;
            margin-top: 6px;
            padding: 4px 0;
            border-top: 1px solid #ddd;
            border-bottom: 1px solid #ddd;
        }
        .two-column {
            display: flex;
            justify-content: space-between;
            gap: 15px;
            margin-bottom: 15px;
        }
        .column {
            flex: 1;
            border: 1.5px solid #333;
            padding: 10px;
        }
        .column h3 {
            font-size: 12px;
            margin-bottom: 6px;
            color: #2563eb;
            font-weight: bold;
            border-bottom: 1px solid #ddd;
            padding-bottom: 3px;
        }
        .buyer-info p, .challan-info p {
            margin: 3px 0;
            font-size: 10px;
        }
        .challan-info {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 5px 10px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 12px;
            border: 1.5px solid #333;
        }
        table th {
            background-color: #e5e7eb;
            font-weight: bold;
            padding: 8px 6px;
            text-align: left;
            border: 1px solid #333;
            font-size: 10px;
        }
        table td {
            padding: 6px;
            border: 1px solid #999;
            font-size: 10px;
        }
        table th.text-center, table td.text-center {
            text-align: center;
        }
        table td.text-right {
            text-align: right;
            padding-right: 15px;
        }
        .items-table tbody tr:nth-child(even) {
            background-color: #f9fafb;
        }
        .declaration {
            border: 1.5px solid #333;
            padding: 8px;
            margin-bottom: 12px;
            font-size: 10px;
        }
        .declaration strong {
            display: block;
            margin-bottom: 4px;
            font-size: 11px;
        }
        .signature-section {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
        }
        .signature-box {
            text-align: right;
            padding: 8px;
            width: 45%;
        }
        .signature-box.receiver {
            text-align: left;
        }
        .signature-box p {
            margin: 3px 0;
            font-size: 11px;
        }
        .signature-space {
            height: 50px;
            margin: 10px 0;
        }
        .footer {
            text-align: center;
            font-size: 9px;
            color: #666;
            border-top: 1px solid #ddd;
            padding-top: 6px;
            font-style: italic;
        }
        strong {
            font-weight: 600;
        }
        .bold {
            font-weight: bold;
        }
    </style>
</head>
<body>
    <!-- Header -->
    <div class="header">
        <h1><%= company.name %></h1>
        <p class="title">DELIVERY CHALLAN</p>
    </div>

    <!-- Company Info -->
    <div class="company-info">
        <%= company.address %>
    </div>
    <div class="company-details">
        <div><strong>GSTIN:</strong> <%= company.gstNo %></div>
        <div><strong>State:</strong> <%= company.stateName %>, Code: <%= company.stateCode %></div>
        <div><strong>Email:</strong> <%= company.email %></div>
    </div>

    <!-- Buyer and Challan Details -->
    <div class="two-column">
        <div class="column buyer-info">
            <h3>Consignee (Ship To)</h3>
            <p><strong><%= receiver.name %></strong></p>
            <p><%= receiver.address %></p>
            <p><strong>GSTIN/UIN:</strong> <%= receiver.gstNo %></p>
            <p><strong>Contact:</strong> <%= receiver.phone %></p>
        </div>
        <div class="column">
            <h3>Challan Details</h3>
            <div class="challan-info">
                <div><strong>Challan No:</strong></div>
                <div style="color: #2563eb; font-weight: bold;"><%= challan.challanNumber %></div>
                
                <div><strong>Challan Date:</strong></div>
                <div><%= challan.date %></div>
                
                <% if (challan.orderNo) { %>
                <div><strong>Order No:</strong></div>
                <div><%= challan.orderNo %></div>
                <% } %>
                
                <div><strong>Dispatch Mode:</strong></div>
                <div><%= challan.dispatchMode || 'Road' %></div>

                <% if (challan.vehicleNo) { %>
                <div><strong>Vehicle No:</strong></div>
                <div><%= challan.vehicleNo %></div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Items Table -->
    <table class="items-table">
        <thead>
            <tr>
                <th style="width: 10%;" class="text-center">Sr. No.</th>
                <th style="width: 50%;">Description of Goods</th>
                <th style="width: 20%;" class="text-center">HSN/SAC</th>
                <th style="width: 10%;" class="text-center">Quantity</th>
                <th style="width: 10%;" class="text-center">Unit</th>
            </tr>
        </thead>
        <tbody>
            <% challan.items.forEach(function(item, i) { %>
            <tr>
                <td class="text-center bold text-slate-900"><%= i + 1 %></td>
                <td><%= item.description %></td>
                <td class="text-center"><%= item.hsn || '-' %></td>
                <td class="text-center bold text-slate-900"><%= item.quantity %></td>
                <td class="text-center"><%= item.unit || 'pcs' %></td>
            </tr>
            <% }) %>
            <% if (challan.totalAmount > 0) { %>
            <tr>
                <td colspan="3" class="text-right bold">Import Duty</td>
                <td colspan="2" class="text-center bold">₹<%= challan.importDuty.toLocaleString('en-IN') %></td>
            </tr>
            <tr>
                <td colspan="3" class="text-right bold">GST Paid</td>
                <td colspan="2" class="text-center bold">₹<%= challan.gstPaid.toLocaleString('en-IN') %></td>
            </tr>
            <tr style="background-color: #f3f4f6;">
                <td colspan="3" class="text-right bold" style="font-size: 12px; color: #2563eb;">Total Bill Amount</td>
                <td colspan="2" class="text-center bold" style="font-size: 12px; color: #2563eb;">₹<%= challan.totalAmount.toLocaleString('en-IN') %></td>
            </tr>
            <% } %>
        </tbody>
    </table>

    <!-- Declaration -->
    <div class="declaration">
        <strong>Declaration:</strong>
        <p>Received the above mentioned materials in good condition and as per specification. This challan is for transport of goods only and not for sale.</p>
    </div>

    <!-- Signature -->
    <div class="signature-section">
        <div class="signature-box receiver">
            <p><strong>Receiver's Signature</strong></p>
            <div class="signature-space"></div>
            <p>Name & Stamp</p>
        </div>
        <div class="signature-box">
            <p><strong>For <%= company.name %></strong></p>
            <div class="signature-space"></div>
            <p>Authorised Signatory</p>
        </div>
    </div>

    <!-- Footer -->
    <div class="footer">
        This is a Computer Generated Delivery Challan
    </div>
</body>
</html>
